{
  "planner": {
    "type": "StepwisePlanner",
    "maxIterations": 6,
    "steps": [
      {
        "stepName": "Multi-Agent-Builder",
        "agentRole": "builder",
        "description": "Multi-Agent builder - implements agent topology, supervisor, handoffs",
        "model": "gpt-4o",
        "tools": [
          "codebase",
          "editFiles",
          "terminal",
          "agent"
        ],
        "order": 1,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/builder.agent.md",
          "waf": [
            "reliability",
            "security",
            "performance-efficiency"
          ]
        }
      },
      {
        "stepName": "Multi-Agent-Reviewer",
        "agentRole": "reviewer",
        "description": "Multi-Agent reviewer - audits agent interactions, loop detection",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase"
        ],
        "order": 2,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/reviewer.agent.md",
          "waf": [
            "security",
            "reliability",
            "responsible-ai"
          ]
        }
      },
      {
        "stepName": "Multi-Agent-Tuner",
        "agentRole": "tuner",
        "description": "Multi-Agent tuner - optimizes routing, per-agent model selection",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase",
          "editFiles",
          "terminal"
        ],
        "order": 3,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/tuner.agent.md",
          "waf": [
            "cost-optimization",
            "performance-efficiency",
            "operational-excellence"
          ]
        }
      }
    ]
  }
}