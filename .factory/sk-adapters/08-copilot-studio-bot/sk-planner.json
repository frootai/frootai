{
  "planner": {
    "type": "StepwisePlanner",
    "maxIterations": 6,
    "steps": [
      {
        "stepName": "Copilot-Studio-Builder",
        "agentRole": "builder",
        "description": "Copilot Studio builder - designs topics, connectors, authentication",
        "model": "gpt-4o",
        "tools": [
          "codebase",
          "editFiles",
          "terminal",
          "agent"
        ],
        "order": 1,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/builder.agent.md",
          "waf": [
            "reliability",
            "security",
            "performance-efficiency"
          ]
        }
      },
      {
        "stepName": "Copilot-Studio-Reviewer",
        "agentRole": "reviewer",
        "description": "Copilot Studio reviewer - audits conversation flows, security",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase"
        ],
        "order": 2,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/reviewer.agent.md",
          "waf": [
            "security",
            "reliability",
            "responsible-ai"
          ]
        }
      },
      {
        "stepName": "Copilot-Studio-Tuner",
        "agentRole": "tuner",
        "description": "Copilot Studio tuner - optimizes topic triggers, knowledge relevance",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase",
          "editFiles",
          "terminal"
        ],
        "order": 3,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/tuner.agent.md",
          "waf": [
            "cost-optimization",
            "performance-efficiency",
            "operational-excellence"
          ]
        }
      }
    ]
  }
}