{
  "planner": {
    "type": "StepwisePlanner",
    "maxIterations": 6,
    "steps": [
      {
        "stepName": "Fine-Tuning-Builder",
        "agentRole": "builder",
        "description": "Fine-Tuning builder - prepares data, configures training, deploys fine-tuned model",
        "model": "gpt-4o",
        "tools": [
          "codebase",
          "editFiles",
          "terminal",
          "agent"
        ],
        "order": 1,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/builder.agent.md",
          "waf": [
            "reliability",
            "operational-excellence",
            "performance-efficiency"
          ]
        }
      },
      {
        "stepName": "Fine-Tuning-Reviewer",
        "agentRole": "reviewer",
        "description": "Fine-Tuning reviewer - audits data quality, overfitting, improvements vs base",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase"
        ],
        "order": 2,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/reviewer.agent.md",
          "waf": [
            "security",
            "reliability",
            "responsible-ai"
          ]
        }
      },
      {
        "stepName": "Fine-Tuning-Tuner",
        "agentRole": "tuner",
        "description": "Fine-Tuning tuner - optimizes hyperparameters, cost/quality trade-offs",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase",
          "editFiles",
          "terminal"
        ],
        "order": 3,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/tuner.agent.md",
          "waf": [
            "cost-optimization",
            "performance-efficiency",
            "operational-excellence"
          ]
        }
      }
    ]
  }
}