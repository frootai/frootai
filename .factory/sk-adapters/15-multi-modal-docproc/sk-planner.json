{
  "planner": {
    "type": "StepwisePlanner",
    "maxIterations": 6,
    "steps": [
      {
        "stepName": "Multi-Modal-DocProc-Builder",
        "agentRole": "builder",
        "description": "Multi-Modal DocProc builder - implements vision+OCR pipeline, table extraction",
        "model": "gpt-4o",
        "tools": [
          "codebase",
          "editFiles",
          "terminal",
          "agent"
        ],
        "order": 1,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/builder.agent.md",
          "waf": [
            "reliability",
            "performance-efficiency",
            "security"
          ]
        }
      },
      {
        "stepName": "Multi-Modal-DocProc-Reviewer",
        "agentRole": "reviewer",
        "description": "Multi-Modal DocProc reviewer - audits extraction accuracy, PII handling",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase"
        ],
        "order": 2,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/reviewer.agent.md",
          "waf": [
            "security",
            "reliability",
            "responsible-ai"
          ]
        }
      },
      {
        "stepName": "Multi-Modal-DocProc-Tuner",
        "agentRole": "tuner",
        "description": "Multi-Modal DocProc tuner - optimizes model selection per doc type, throughput",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase",
          "editFiles",
          "terminal"
        ],
        "order": 3,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/tuner.agent.md",
          "waf": [
            "cost-optimization",
            "performance-efficiency",
            "operational-excellence"
          ]
        }
      }
    ]
  }
}