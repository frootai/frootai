{
  "planner": {
    "type": "StepwisePlanner",
    "maxIterations": 6,
    "steps": [
      {
        "stepName": "Prompt-Management-Builder",
        "agentRole": "builder",
        "description": "Prompt Management builder - implements prompt registry, templates, A/B testing",
        "model": "gpt-4o",
        "tools": [
          "codebase",
          "editFiles",
          "terminal",
          "agent"
        ],
        "order": 1,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/builder.agent.md",
          "waf": [
            "operational-excellence",
            "security",
            "reliability"
          ]
        }
      },
      {
        "stepName": "Prompt-Management-Reviewer",
        "agentRole": "reviewer",
        "description": "Prompt Management reviewer - audits prompt quality, injection risks, versioning",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase"
        ],
        "order": 2,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/reviewer.agent.md",
          "waf": [
            "security",
            "reliability",
            "responsible-ai"
          ]
        }
      },
      {
        "stepName": "Prompt-Management-Tuner",
        "agentRole": "tuner",
        "description": "Prompt Management tuner - optimizes prompts via A/B, reduces tokens",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase",
          "editFiles",
          "terminal"
        ],
        "order": 3,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/tuner.agent.md",
          "waf": [
            "cost-optimization",
            "performance-efficiency",
            "operational-excellence"
          ]
        }
      }
    ]
  }
}