{
  "planner": {
    "type": "StepwisePlanner",
    "maxIterations": 6,
    "steps": [
      {
        "stepName": "MCP-Gateway-Builder",
        "agentRole": "builder",
        "description": "MCP Gateway builder - implements MCP server, tools, resources, transport",
        "model": "gpt-4o",
        "tools": [
          "codebase",
          "editFiles",
          "terminal",
          "agent"
        ],
        "order": 1,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/builder.agent.md",
          "waf": [
            "security",
            "reliability",
            "operational-excellence"
          ]
        }
      },
      {
        "stepName": "MCP-Gateway-Reviewer",
        "agentRole": "reviewer",
        "description": "MCP Gateway reviewer - audits tool security, input validation, errors",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase"
        ],
        "order": 2,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/reviewer.agent.md",
          "waf": [
            "security",
            "reliability",
            "responsible-ai"
          ]
        }
      },
      {
        "stepName": "MCP-Gateway-Tuner",
        "agentRole": "tuner",
        "description": "MCP Gateway tuner - optimizes tool descriptions, response format",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase",
          "editFiles",
          "terminal"
        ],
        "order": 3,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/tuner.agent.md",
          "waf": [
            "cost-optimization",
            "performance-efficiency",
            "operational-excellence"
          ]
        }
      }
    ]
  }
}