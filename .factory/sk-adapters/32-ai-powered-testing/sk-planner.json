{
  "planner": {
    "type": "StepwisePlanner",
    "maxIterations": 6,
    "steps": [
      {
        "stepName": "AI-Testing-Builder",
        "agentRole": "builder",
        "description": "AI Testing builder - generates tests from source AST, mutation testing, CI",
        "model": "gpt-4o",
        "tools": [
          "codebase",
          "editFiles",
          "terminal",
          "agent"
        ],
        "order": 1,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/builder.agent.md",
          "waf": [
            "reliability",
            "operational-excellence",
            "security"
          ]
        }
      },
      {
        "stepName": "AI-Testing-Reviewer",
        "agentRole": "reviewer",
        "description": "AI Testing reviewer - audits test quality, mock completeness, coverage",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase"
        ],
        "order": 2,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/reviewer.agent.md",
          "waf": [
            "security",
            "reliability",
            "operational-excellence"
          ]
        }
      },
      {
        "stepName": "AI-Testing-Tuner",
        "agentRole": "tuner",
        "description": "AI Testing tuner - optimizes test prioritization, reduces flaky tests",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase",
          "editFiles",
          "terminal"
        ],
        "order": 3,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/tuner.agent.md",
          "waf": [
            "cost-optimization",
            "performance-efficiency",
            "reliability"
          ]
        }
      }
    ]
  }
}