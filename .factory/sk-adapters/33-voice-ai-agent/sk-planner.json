{
  "planner": {
    "type": "StepwisePlanner",
    "maxIterations": 6,
    "steps": [
      {
        "stepName": "Voice-AI-Agent-Builder",
        "agentRole": "builder",
        "description": "Voice AI Agent builder - implements voice loop, dialog state, intent detection",
        "model": "gpt-4o",
        "tools": [
          "codebase",
          "editFiles",
          "terminal",
          "agent"
        ],
        "order": 1,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/builder.agent.md",
          "waf": [
            "reliability",
            "performance-efficiency",
            "security"
          ]
        }
      },
      {
        "stepName": "Voice-AI-Agent-Reviewer",
        "agentRole": "reviewer",
        "description": "Voice AI Agent reviewer - audits latency, escalation, compliance, UX",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase"
        ],
        "order": 2,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/reviewer.agent.md",
          "waf": [
            "security",
            "reliability",
            "responsible-ai"
          ]
        }
      },
      {
        "stepName": "Voice-AI-Agent-Tuner",
        "agentRole": "tuner",
        "description": "Voice AI Agent tuner - optimizes response speed, voice quality, accuracy",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase",
          "editFiles",
          "terminal"
        ],
        "order": 3,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/tuner.agent.md",
          "waf": [
            "cost-optimization",
            "performance-efficiency",
            "reliability"
          ]
        }
      }
    ]
  }
}