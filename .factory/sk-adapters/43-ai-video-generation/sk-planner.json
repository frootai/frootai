{
  "planner": {
    "type": "StepwisePlanner",
    "maxIterations": 6,
    "steps": [
      {
        "stepName": "Video-Generation-Builder",
        "agentRole": "builder",
        "description": "Video Generation builder - implements generation pipeline, batch processing, safety",
        "model": "gpt-4o",
        "tools": [
          "codebase",
          "editFiles",
          "terminal",
          "agent"
        ],
        "order": 1,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/builder.agent.md",
          "waf": [
            "reliability",
            "performance-efficiency",
            "cost-optimization"
          ]
        }
      },
      {
        "stepName": "Video-Generation-Reviewer",
        "agentRole": "reviewer",
        "description": "Video Generation reviewer - audits content safety, copyright, watermarking",
