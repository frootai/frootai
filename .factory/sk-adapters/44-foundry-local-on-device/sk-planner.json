{
  "planner": {
    "type": "StepwisePlanner",
    "maxIterations": 6,
    "steps": [
      {
        "stepName": "Foundry-Local-Builder",
        "agentRole": "builder",
        "description": "Foundry Local builder - sets up Foundry Local, model config, hybrid routing",
        "model": "gpt-4o",
        "tools": [
          "codebase",
          "editFiles",
          "terminal",
          "agent"
        ],
        "order": 1,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/builder.agent.md",
          "waf": [
            "reliability",
            "performance-efficiency",
            "cost-optimization"
          ]
        }
      },
      {
        "stepName": "Foundry-Local-Reviewer",
        "agentRole": "reviewer",
        "description": "Foundry Local reviewer - audits hardware compatibility, fallback, offline",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase"
        ],
        "order": 2,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/reviewer.agent.md",
          "waf": [
            "security",
            "reliability",
            "responsible-ai"
          ]
        }
      },
      {
        "stepName": "Foundry-Local-Tuner",
        "agentRole": "tuner",
        "description": "Foundry Local tuner - optimizes model selection per device, cost savings",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase",
          "editFiles",
          "terminal"
        ],
        "order": 3,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/tuner.agent.md",
          "waf": [
            "cost-optimization",
            "performance-efficiency",
            "operational-excellence"
          ]
        }
      }
    ]
  }
}