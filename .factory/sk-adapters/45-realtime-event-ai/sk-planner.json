        "tools": [
          "codebase"
        ],
        "order": 2,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/reviewer.agent.md",
          "waf": [
            "reliability",
            "security",
            "operational-excellence"
          ]
        }
      },
      {
        "stepName": "Realtime-Event-AI-Tuner",
        "agentRole": "tuner",
        "description": "Realtime Event AI tuner - optimizes batch size, anomaly thresholds, LLM ratio",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase",
          "editFiles",
          "terminal"
        ],
        "order": 3,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/tuner.agent.md",
