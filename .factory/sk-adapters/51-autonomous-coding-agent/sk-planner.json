{
  "planner": {
    "type": "StepwisePlanner",
    "maxIterations": 6,
    "steps": [
      {
        "stepName": "Autonomous-Coding-Builder",
        "agentRole": "builder",
        "description": "Autonomous Coding builder - implements issue-to-PR, multi-file changes, test gen",
        "model": "gpt-4o",
        "tools": [
          "codebase",
          "editFiles",
          "terminal",
          "agent"
        ],
        "order": 1,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/builder.agent.md",
          "waf": [
            "reliability",
            "operational-excellence",
            "performance-efficiency"
          ]
        }
      },
      {
        "stepName": "Autonomous-Coding-Reviewer",
        "agentRole": "reviewer",
        "description": "Autonomous Coding reviewer - audits code quality, test coverage, PR completeness",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase"
        ],
        "order": 2,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/reviewer.agent.md",
          "waf": [
            "security",
            "reliability",
            "operational-excellence"
          ]
        }
      },
      {
        "stepName": "Autonomous-Coding-Tuner",
        "agentRole": "tuner",
        "description": "Autonomous Coding tuner - optimizes plan quality, iteration count, coverage",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase",
          "editFiles",
          "terminal"
        ],
        "order": 3,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/tuner.agent.md",
          "waf": [
            "cost-optimization",
            "performance-efficiency",
            "reliability"
          ]
        }
      }
    ]
  }
}