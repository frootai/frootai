{
  "planner": {
    "type": "StepwisePlanner",
    "maxIterations": 6,
    "steps": [
      {
        "stepName": "Translation-Engine-Builder",
        "agentRole": "builder",
        "description": "Translation Engine builder - implements translation pipeline, glossary, post-editing",
        "model": "gpt-4o",
        "tools": [
          "codebase",
          "editFiles",
          "terminal",
          "agent"
        ],
        "order": 1,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/builder.agent.md",
          "waf": [
            "reliability",
            "performance-efficiency",
            "cost-optimization"
          ]
        }
      },
      {
        "stepName": "Translation-Engine-Reviewer",
        "agentRole": "reviewer",
        "description": "Translation Engine reviewer - audits quality, glossary completeness, locale handling",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase"
        ],
        "order": 2,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/reviewer.agent.md",
          "waf": [
            "responsible-ai",
            "reliability",
            "operational-excellence"
          ]
        }
      },
      {
        "stepName": "Translation-Engine-Tuner",
        "agentRole": "tuner",
        "description": "Translation Engine tuner - optimizes LLM refinement ratio, quality thresholds",
        "model": "gpt-4o-mini",
        "tools": [
          "codebase",
          "editFiles",
          "terminal"
        ],
        "order": 3,
        "metadata": {
          "source": "fai-agent",
          "originalPath": "./.github/agents/tuner.agent.md",
          "waf": [
            "cost-optimization",
            "performance-efficiency",
            "reliability"
          ]
        }
      }
    ]
  }
}