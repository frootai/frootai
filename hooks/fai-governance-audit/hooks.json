{
  "version": 1,
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "bash hooks/fai-governance-audit/audit-prompt.sh",
        "windows": "powershell -NoProfile -Command \"Write-Output '{}'\"",
        "cwd": ".",
        "env": {
          "AUDIT_LEVEL": "standard"
        },
        "timeout": 10
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "bash hooks/fai-governance-audit/audit-prompt.sh",
        "windows": "powershell -NoProfile -Command \"Write-Output '{}'\"",
        "cwd": ".",
        "env": {
          "AUDIT_LEVEL": "standard",
          "AUDIT_EVENT": "sessionStart"
        },
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash hooks/fai-governance-audit/audit-prompt.sh",
        "windows": "powershell -NoProfile -Command \"Write-Output '{}'\"",
        "cwd": ".",
        "env": {
          "AUDIT_LEVEL": "standard",
          "AUDIT_EVENT": "sessionEnd"
        },
        "timeout": 5
      }
    ]
  }
}