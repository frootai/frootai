{
  "version": 1,
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": "bash hooks/fai-secrets-scanner/scan-secrets.sh",
        "windows": "powershell -NoProfile -Command \"Write-Output '{}'\"",
        "cwd": ".",
        "env": {
          "SCAN_MODE": "warn",
          "SCAN_SCOPE": "diff"
        },
        "timeout": 30
      }
    ]
  }
}