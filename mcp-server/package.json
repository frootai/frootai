{
  "name": "frootai-mcp",
  "version": "5.0.1",
  "description": "FrootAI™ MCP Server v5 — AI architecture knowledge + compute tools. 39 tools: 6 static + 4 live + 3 chain + 9 ecosystem + 3 compute. 16 modules, 200+ terms, 101 solution plays, 830+ primitives.",
  "main": "index.js",
  "type": "module",
  "bin": {
    "frootai-mcp": "./index.js",
    "frootai": "./cli.js"
  },
  "files": [
    "index.js",
    "cli.js",
    "knowledge.json",
    "README.md"
  ],
  "scripts": {
    "start": "node index.js",
    "start:http": "node index.js http",
    "build": "node build-knowledge.js && tsc --noEmit",
    "build:ts": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node build-knowledge.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "architecture",
    "azure",
    "llm",
    "rag",
    "agents",
    "frootai",
    "knowledge-base",
    "semantic-kernel",
    "copilot"
  ],
  "author": "FrootAI Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/frootai/frootai"
  },
  "homepage": "https://frootai.dev",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
