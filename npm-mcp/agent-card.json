{
  "$schema": "https://a2a-protocol.dev/schema/agent-card.json",
  "_comment": "A2A (Agent-to-Agent) Protocol Agent Card — Google's open protocol for agent interoperability",
  "name": "FrootAI Architecture Agent",
  "description": "AI architecture knowledge agent that helps infrastructure and platform teams design, deploy, and operate AI solutions. Provides 16 FROOT knowledge modules, 200+ AI terms, model recommendations, cost estimates, and guided build\u2192review\u2192tune workflows.",
  "version": "5.0.1",
  "url": "https://frootai-mcp.azurewebsites.net",
  "provider": {
    "name": "FrootAI",
    "url": "https://frootai.dev"
  },
  "protocols": [
    "MCP/1.0",
    "A2A/1.0"
  ],
  "capabilities": {
    "knowledge": {
      "query": true,
      "search": true,
      "modules": 16,
      "terms": 200
    },
    "planning": {
      "architecture_patterns": true,
      "model_selection": true,
      "cost_estimation": true
    },
    "workflow": {
      "build_review_tune": true,
      "agent_chain": [
        "agent_build",
        "agent_review",
        "agent_tune"
      ]
    },
    "retrieval": {
      "azure_docs": true,
      "external_mcp_registry": true,
      "community_plays": true
    }
  },
  "skills": [
    {
      "id": "knowledge",
      "name": "FROOT Knowledge Query",
      "description": "Search and retrieve AI architecture knowledge across 18 modules and 200+ terms",
      "inputModes": [
        "text"
      ],
      "outputModes": [
        "text"
      ]
    },
    {
      "id": "model_advisor",
      "name": "AI Model Advisor",
      "description": "Compare Azure OpenAI models, estimate costs, recommend the right model for a use case",
      "inputModes": [
        "text"
      ],
      "outputModes": [
        "text"
      ]
    },
    {
      "id": "solution_architect",
      "name": "Solution Architecture Guide",
      "description": "Guide through 23 pre-packaged solution plays with DevKit + TuneKit configurations",
      "inputModes": [
        "text"
      ],
      "outputModes": [
        "text"
      ]
    },
    {
      "id": "build_review_tune",
      "name": "Build → Review → Tune Workflow",
      "description": "Three-agent chain: Builder creates, Reviewer validates, Tuner optimizes for production",
      "inputModes": [
        "text"
      ],
      "outputModes": [
        "text"
      ]
    }
  ],
  "authentication": {
    "schemes": [
      "none"
    ],
    "_comment": "FrootAI MCP is open source — no authentication required for read-only knowledge queries. Azure-deployed instances can add Managed Identity auth."
  },
  "tools": {
    "mcp_tools": 45,
    "categories": {
      "knowledge": [
        "list_modules", "get_module", "lookup_term", "search_knowledge",
        "get_architecture_pattern", "get_froot_overview"
      ],
      "live": [
        "fetch_azure_docs", "fetch_external_mcp",
        "list_community_plays", "get_github_agentic_os"
      ],
      "agent_chain": [
        "agent_build", "agent_review", "agent_tune"
      ],
      "ecosystem": [
        "get_model_catalog", "get_azure_pricing", "estimate_cost",
        "compare_models", "compare_plays", "semantic_search_plays",
        "embedding_playground", "run_evaluation", "validate_config",
        "generate_architecture_diagram"
      ],
      "engine": [
        "wire_play", "inspect_wiring", "validate_manifest",
        "get_play_detail", "list_primitives", "evaluate_quality"
      ],
      "scaffold": [
        "scaffold_play", "create_primitive", "smart_scaffold"
      ],
      "marketplace": [
        "marketplace_search", "marketplace_browse", "install_plugin",
        "uninstall_plugin", "list_installed", "check_compatibility",
        "validate_plugin", "compose_plugins", "publish_plugin",
        "check_plugin_updates", "resolve_dependencies",
        "list_external_plugins", "marketplace_stats"
      ]
    }
  }
}