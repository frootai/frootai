{
  "$schema": "https://registry.mcp.dev/schema/v1/entry.json",
  "name": "frootai-mcp",
  "displayName": "FrootAI — FAI Engine Runtime Interface",
  "version": "5.0.1",
  "description": "45 tools, 18 modules, 100 solution plays, 860+ primitives. The open glue for the GenAI ecosystem — FAI Engine, Build→Review→Tune, scaffolding, marketplace.",
  "longDescription": "FrootAI MCP Server is the FAI Engine's network interface. It wires AI primitives (agents, skills, instructions, hooks) into solution plays using the FAI Protocol. 45 tools across 7 categories: Knowledge, Live, Agent Chain, Ecosystem, Engine, Scaffold, and Marketplace. Includes Streamable HTTP transport, OTel telemetry, resource templates, 4 MCP prompts, and A2A agent card.",
  "author": {
    "name": "FrootAI Contributors",
    "url": "https://frootai.dev",
    "github": "frootai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/frootai/frootai"
  },
  "homepage": "https://frootai.dev",
  "documentation": "https://frootai.dev/setup-guide",
  "install": {
    "npm": "npx frootai-mcp@latest",
    "global": "npm install -g frootai-mcp",
    "http": "node index.js http"
  },
  "transport": ["stdio", "streamable-http"],
  "runtime": "node",
  "engines": {
    "node": ">=18.0.0"
  },
  "categories": [
    "ai-architecture", "azure", "knowledge-base", "agents",
    "mcp", "devops", "cloud-infrastructure", "scaffolding", "marketplace"
  ],
  "tags": [
    "ai", "architecture", "azure", "llm", "rag", "agents", "mcp", "fai-protocol",
    "semantic-kernel", "copilot", "openai", "knowledge", "glossary",
    "infrastructure", "platform-engineering", "cost-optimization",
    "model-selection", "solution-plays", "devkit", "tunekit", "scaffold"
  ],
  "compatibility": {
    "clients": [
      "claude-desktop", "vscode-copilot", "cursor", "windsurf",
      "azure-ai-foundry", "continue-dev", "gemini-cli", "jetbrains"
    ],
    "protocols": ["MCP/1.0", "A2A/1.0"]
  },
  "tools": {
    "count": 45,
    "categories": {
      "knowledge (6)": ["list_modules", "get_module", "lookup_term", "search_knowledge", "get_architecture_pattern", "get_froot_overview"],
      "live (4)": ["fetch_azure_docs", "fetch_external_mcp", "list_community_plays", "get_github_agentic_os"],
      "agent-chain (3)": ["agent_build", "agent_review", "agent_tune"],
      "ecosystem (10)": ["get_model_catalog", "get_azure_pricing", "estimate_cost", "compare_models", "compare_plays", "semantic_search_plays", "embedding_playground", "run_evaluation", "validate_config", "generate_architecture_diagram"],
      "engine (6)": ["wire_play", "inspect_wiring", "validate_manifest", "get_play_detail", "list_primitives", "evaluate_quality"],
      "scaffold (3)": ["scaffold_play", "create_primitive", "smart_scaffold"],
      "marketplace (13)": ["marketplace_search", "marketplace_browse", "install_plugin", "uninstall_plugin", "list_installed", "check_compatibility", "validate_plugin", "compose_plugins", "publish_plugin", "check_plugin_updates", "resolve_dependencies", "list_external_plugins", "marketplace_stats"]
    }
  },
  "resources": {
    "count": "18+ (one per FROOT module + schemas)",
    "uriScheme": "fai://",
    "examples": ["fai://overview", "fai://module/F1", "fai://schema/fai-manifest"]
  },
  "prompts": {
    "count": 4,
    "names": ["build", "review", "tune", "wire"]
  },
  "knowledge": {
    "modules": 18,
    "terms": 200,
    "plays": 100,
    "primitives": 830,
    "bundledSize": "688 KB",
    "framework": "FROOT (Foundations · Reasoning · Orchestration · Operations · Transformation)"
  },
  "metrics": {
    "tokenEfficiency": "90% reduction vs internet search",
    "responseLatency": "<100ms knowledge tools, <2s live tools",
    "startupTime": "<5s cold start",
    "e2eTests": 41
  }
}
