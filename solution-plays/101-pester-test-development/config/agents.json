{
  "play": "101-pester-test-development",
  "chain": "builder → reviewer → tuner",
  "agents": {
    "builder": {
      "file": ".github/agents/builder.agent.md",
      "role": "Test generator — AST analysis, testability assessment, Pester 5.x test generation",
      "temperature": 0.1,
      "tools": ["powershell", "pester", "psscriptanalyzer", "git"],
      "phases": ["discovery", "assessment", "requirement-mapping", "dependency-mapping", "refactoring", "test-generation"]
    },
    "reviewer": {
      "file": ".github/agents/reviewer.agent.md",
      "role": "Test quality reviewer — mock verification, assertion quality, coverage analysis",
      "temperature": 0.0,
      "tools": ["powershell", "pester"],
      "checks": ["structure", "mocking", "assertions", "coverage", "isolation", "security", "cicd"]
    },
    "tuner": {
      "file": ".github/agents/tuner.agent.md",
      "role": "Coverage optimizer — close gaps, eliminate flaky tests, CI/CD pipeline configuration",
      "temperature": 0.1,
      "tools": ["powershell", "pester", "git"],
      "targets": {
        "line_coverage": 90,
        "branch_coverage": 80,
        "function_coverage": 100,
        "test_pass_rate": 100,
        "max_test_duration_seconds": 5,
        "flaky_test_rate": 0
      }
    }
  },
  "escalation": {
    "trigger": "coverage < 85% OR flaky_test_rate > 1%",
    "action": "human-in-the-loop"
  }
}
