{
  "_comment": "Data processing configuration for Pester Test Development",
  "strategy": "semantic",
  "chunk_size_tokens": 512,
  "chunk_overlap_percent": 10,
  "max_chunks_per_document": 100,
  "supported_formats": [
    "pdf",
    "docx",
    "txt",
    "md",
    "html",
    "json"
  ],
  "preprocessing": {
    "strip_headers_footers": true,
    "normalize_whitespace": true,
    "extract_tables": true
  },
  "embedding": {
    "model": "PSScriptAnalyzer",
    "dimensions": 3072
  }
}