{
    "inputs": [
        {
            "type": "promptString",
            "id": "azure-ml-workspace",
            "description": "Azure ML Workspace name",
            "password": false
        },
        {
            "type": "promptString",
            "id": "huggingface-token",
            "description": "HuggingFace API token (for model/dataset downloads)",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}