{
    "inputs": [
        {
            "type": "promptString",
            "id": "log-analytics-workspace-id",
            "description": "Log Analytics Workspace ID for anomaly data source",
            "password": false
        },
        {
            "type": "promptString",
            "id": "azure-openai-key",
            "description": "Azure OpenAI API Key for root cause analysis (leave blank if using Managed Identity)",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}