{
    "inputs": [
        {
            "type": "promptString",
            "id": "azure-openai-key",
            "description": "Azure OpenAI API Key (leave blank if using Managed Identity)",
            "password": true
        },
        {
            "type": "promptString",
            "id": "redis-connection",
            "description": "Redis connection string for swarm state coordination",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}