{
    "inputs": [
        {
            "type": "promptString",
            "id": "azure-openai-key",
            "description": "Azure OpenAI API Key for vision-based page analysis (leave blank if using Managed Identity)",
            "password": true
        },
        {
            "type": "promptString",
            "id": "target-base-url",
            "description": "Base URL of the target web application to automate",
            "password": false
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}