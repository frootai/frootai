{
    "inputs": [
        {
            "type": "promptString",
            "id": "cosmos-gremlin-endpoint",
            "description": "Cosmos DB Gremlin endpoint for knowledge graph",
            "password": false
        },
        {
            "type": "promptString",
            "id": "cosmos-gremlin-key",
            "description": "Cosmos DB Gremlin primary key (leave blank if using Managed Identity)",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}