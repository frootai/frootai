{
    "inputs": [
        {
            "type": "promptString",
            "id": "backend-api-key",
            "description": "API key for the backend service the MCP server wraps",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}