{
    "inputs": [
        {
            "type": "promptString",
            "id": "azure-speech-key",
            "description": "Azure Speech Service Key for transcription + diarization",
            "password": true
        },
        {
            "type": "promptString",
            "id": "azure-openai-key",
            "description": "Azure OpenAI API Key for summarization + action item extraction",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}