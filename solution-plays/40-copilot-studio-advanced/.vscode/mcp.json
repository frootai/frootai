{
    "inputs": [
        {
            "type": "promptString",
            "id": "power-platform-client-id",
            "description": "Power Platform / Entra ID App Registration Client ID for Copilot Studio",
            "password": false
        },
        {
            "type": "promptString",
            "id": "azure-openai-key",
            "description": "Azure OpenAI API Key for plugin orchestration",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}