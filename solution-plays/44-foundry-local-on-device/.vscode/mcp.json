{
    "inputs": [
        {
            "type": "promptString",
            "id": "azure-openai-key",
            "description": "Azure OpenAI API Key for cloud fallback inference",
            "password": true
        },
        {
            "type": "promptString",
            "id": "foundry-local-cache-path",
            "description": "Local path for Foundry Local model cache (e.g., ~/.foundry-local/models)",
            "password": false
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}