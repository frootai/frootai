{
    "inputs": [
        {
            "type": "promptString",
            "id": "eventhub-connection-string",
            "description": "Azure Event Hubs connection string for event ingestion",
            "password": true
        },
        {
            "type": "promptString",
            "id": "azure-openai-key",
            "description": "Azure OpenAI API Key for batch event enrichment",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}