{
    "inputs": [
        {
            "type": "promptString",
            "id": "github-token",
            "description": "GitHub Personal Access Token for issue reading and PR creation",
            "password": true
        },
        {
            "type": "promptString",
            "id": "azure-openai-key",
            "description": "Azure OpenAI API Key for code generation and analysis",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}