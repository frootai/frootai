{
    "inputs": [
        {
            "type": "promptString",
            "id": "azure-openai-key",
            "description": "Azure OpenAI API Key for legal document analysis (GPT-4o)",
            "password": true
        },
        {
            "type": "promptString",
            "id": "azure-doc-intelligence-key",
            "description": "Azure Document Intelligence Key for contract layout extraction",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}