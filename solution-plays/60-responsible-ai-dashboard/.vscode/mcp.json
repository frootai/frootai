{
    "inputs": [
        {
            "type": "promptString",
            "id": "azure-openai-key",
            "description": "Azure OpenAI API Key for RAI report generation and summaries",
            "password": true
        },
        {
            "type": "promptString",
            "id": "app-insights-connection",
            "description": "Application Insights connection string for metrics collection",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}