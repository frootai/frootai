{
    "inputs": [
        {
            "type": "promptString",
            "id": "azure-openai-key",
            "description": "Azure OpenAI API Key for lead scoring and email generation",
            "password": true
        },
        {
            "type": "promptString",
            "id": "crm-api-key",
            "description": "CRM API Key (Salesforce, HubSpot, or Dynamics 365)",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}