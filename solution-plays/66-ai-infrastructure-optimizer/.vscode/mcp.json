{
    "inputs": [
        {
            "type": "promptString",
            "id": "azure-subscription-id",
            "description": "Azure Subscription ID for resource monitoring and cost analysis",
            "password": false
        },
        {
            "type": "promptString",
            "id": "azure-openai-key",
            "description": "Azure OpenAI API Key for recommendation explanations",
            "password": true
        }
    ],
    "servers": {
        "frootai": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "frootai-mcp@latest"
            ],
            "envFile": "${workspaceFolder}/.env"
        }
    }
}