      "responsible-ai",
      "reliability",
      "performance-efficiency"
    ]
  },
  "primitives": {
    "agents": [
      "builder.agent.md",
      "reviewer.agent.md",
      "tuner.agent.md"
    ],
    "instructions": [
      "75-patterns.instructions.md"
    ],
    "skills": [
      "deploy-75/",
      "evaluate-75/",
      "tune-75/"
    ],
    "hooks": [
      "../../hooks/frootai-secrets-scanner/",
      "../../hooks/frootai-tool-guardian/",
      "../../hooks/frootai-governance-audit/"
    ]
  },
  "infrastructure": {
    "services": [
      "Azure OpenAI",
      "Azure Blob Storage",
      "Azure Cosmos DB",
      "Azure Functions"
    ],
    "template": "infra/main.bicep",
