{
  "play": "75-exam-generation-engine",
  "version": "1.0.0",
  "description": "Auto-generate exams from curriculum with difficulty calibration, rubric generation, answer key creation, and anti-cheating question variation.",
  "context": {
    "knowledge": [
      "F1-GenAI-Foundations",
      "R1-Prompt-Engineering",
      "T2-Responsible-AI"
    ],
